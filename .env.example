# ────────────────────────────────────────────
# zgen Magazine — Variables de entorno
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a GitHub.
# ────────────────────────────────────────────

# URL pública del sitio (cambiar en producción)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Base de datos (ejemplo con Supabase) ───
# DATABASE_URL=postgresql://user:password@host:5432/zgen_magazine

# ─── Almacenamiento de imágenes ─────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Pagos (Stripe — para más adelante) ─────
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (para contacto/notificaciones) ───
# RESEND_API_KEY=re_...

# ─── Analytics ──────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
